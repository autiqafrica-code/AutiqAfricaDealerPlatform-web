# =============================================================================
# Autiq Africa — Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# Any variable without the VITE_ prefix is server-side only and ignored by Vite.
#
# NOTE: The frontend currently uses mock data (src/data/mockData.js) and does
# NOT call the backend API. These env vars are placeholders for the upcoming
# API integration phase.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# VITE_API_BASE_URL: Base URL for all API calls.
# Must match the PORT in backend/.env (default: 8005).
VITE_API_BASE_URL=http://localhost:8005/api

# -----------------------------------------------------------------------------
# App Metadata
# -----------------------------------------------------------------------------
VITE_APP_NAME=Autiq Africa
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# Feature Flags (future use)
# -----------------------------------------------------------------------------
# VITE_ENABLE_WHATSAPP=false
# VITE_ENABLE_EMAIL_NOTIFICATIONS=false
# VITE_ENABLE_CUSTOMER_PORTAL=true
