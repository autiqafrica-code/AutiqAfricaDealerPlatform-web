# =============================================================================
# Autiq Africa — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Minimum required to start: DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
# PORT: Backend API port. Must match VITE_API_BASE_URL in frontend/.env.local
#       and admin/.env.local. Default: 8005
PORT=8005

# -----------------------------------------------------------------------------
# Database (Prisma + PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# The database autiq_africa_db must already exist before running migrations.
# Local default (adjust user/password to match your PostgreSQL setup):
DATABASE_URL="postgresql://postgres:admin@localhost:5432/autiq_africa_db?schema=public"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# JWT_SECRET: Signs access tokens (8h expiry). Use a random 64+ character string.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_random_64_char_hex_string_for_access_tokens

# JWT_EXPIRES_IN: Access token lifetime. Examples: 8h, 1d, 30m
JWT_EXPIRES_IN=8h

# JWT_REFRESH_SECRET: Signs refresh tokens (7d expiry). Must be different from JWT_SECRET.
JWT_REFRESH_SECRET=replace_with_a_different_random_64_char_hex_string_for_refresh_tokens

# JWT_REFRESH_EXPIRES_IN: Refresh token lifetime.
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS — Allowed Origins
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed to call the API.
# Include all ports your frontend and admin apps run on.
# No trailing slashes. No wildcards (credentials: true requires explicit origins).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8174,http://localhost:5174,http://localhost:5175,http://localhost:4173

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
# UPLOAD_DIR: Directory for uploaded files (relative to backend/). Created automatically.
UPLOAD_DIR=uploads

# MAX_FILE_SIZE_MB: Maximum file size per upload request (in megabytes).
MAX_FILE_SIZE_MB=20

# -----------------------------------------------------------------------------
# WhatsApp Notifications (optional — leave blank until provider is configured)
# -----------------------------------------------------------------------------
# WHATSAPP_API_URL: Your WhatsApp Business API base URL (e.g., Meta Cloud API endpoint)
WHATSAPP_API_URL=

# WHATSAPP_API_TOKEN: Bearer token for authenticating with the WhatsApp API
WHATSAPP_API_TOKEN=

# -----------------------------------------------------------------------------
# Email / SMTP (optional — leave blank until SMTP provider is configured)
# -----------------------------------------------------------------------------
# SMTP_HOST: SMTP server hostname (e.g., smtp.sendgrid.net, smtp.mailgun.org)
SMTP_HOST=

# SMTP_PORT: 587 (STARTTLS) or 465 (SSL)
SMTP_PORT=587

# SMTP_USER: SMTP username / API key username
SMTP_USER=

# SMTP_PASS: SMTP password or API key. NEVER hardcode — always use .env
SMTP_PASS=

# EMAIL_FROM: The "From" address for all outgoing emails
EMAIL_FROM=noreply@autiqafrica.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS: Time window in milliseconds. Default: 900000 = 15 minutes
RATE_LIMIT_WINDOW_MS=900000

# RATE_LIMIT_MAX: Max requests per IP per window. Auth endpoints use a stricter limit (20).
RATE_LIMIT_MAX=200

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL: Winston log level. Options: error, warn, info, http, debug
# Use "debug" in development, "warn" or "error" in production.
LOG_LEVEL=debug

# LOG_DIR: Absolute path to the directory where log files are written.
# The directory is created automatically on startup if it does not exist.
# Produces: error.log (errors only) and combined.log (all levels), both JSON, max 10 rotations.
LOG_DIR=C:\ATGrubgainPlatform\AutiqAfricaDealerPlatform\logs
